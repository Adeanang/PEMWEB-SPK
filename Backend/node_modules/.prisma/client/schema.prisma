generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role

  hotels              Hotel[]
  rekomendasiRequests RekomendasiRequest[]
  bookings            Booking[]

  @@map("user")
}

model Hotel {
  id          Int     @id @default(autoincrement())
  name        String
  location    String
  sosialMedia String? @map("sosial_media")
  imageHotel  String? @map("image_hotel")
  lat         Float?
  lng         Float?

  userId          Int @map("id_user")
  kategoriHotelId Int @map("id_kategori_hotel")

  user          User          @relation(fields: [userId], references: [id])
  kategoriHotel KategoriHotel @relation(fields: [kategoriHotelId], references: [id])

  kategoriKamars  KategoriKamar[]
  kamars          Kamar[]
  fasilitasHotels FasilitasHotel[]
  hotelKriterias  HotelKriteria[] // ini yang dipakai
  resultRequests  ResultRequest[]

  @@map("hotel")
}

model KategoriHotel {
  id           Int    @id @default(autoincrement())
  namaKategori String @map("nama_kategori")

  hotels              Hotel[]
  rekomendasiRequests RekomendasiRequest[]

  @@map("kategori_hotel")
}

model KategoriKamar {
  id             Int     @id @default(autoincrement()) @map("id_kamar")
  hotelId        Int     @map("id_hotel")
  namaKategori   String  @map("nama_kategori")
  deskripsi      String?
  kapasitasOrang String  @map("kapasitas_orang")
  hargaMin       Int?
  hargaMax       Int?

  hotel  Hotel   @relation(fields: [hotelId], references: [id])
  kamars Kamar[]

  @@map("kategori_kamar")
}

model Kamar {
  id         Int    @id @default(autoincrement()) @map("id_kamar")
  hotelId    Int    @map("id_hotel")
  kategoriId Int    @map("id_kategori")
  nomorKamar String @map("nomor_kamar")

  hotel    Hotel         @relation(fields: [hotelId], references: [id])
  kategori KategoriKamar @relation(fields: [kategoriId], references: [id])
  bookings Booking[]

  @@unique([hotelId, nomorKamar])
  @@map("kamar")
}

model FasilitasHotel {
  id        Int    @id @default(autoincrement()) @map("id_fasilitas")
  hotelId   Int    @map("id_hotel")
  fasilitas String

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("fasilitas_hotel")
}

model Kriteria {
  id    Int    @id @default(autoincrement()) @map("id_kriteria")
  kode  String @unique
  nama  String
  bobot Float

  jenis JenisKriteria

  subKriterias     SubKriteria[]
  hotelKriterias   HotelKriteria[]
  requestKriterias RekomendasiReqKriteria[]

  perbandinganSebagaiKriteria1 PerbandinganKriteria[] @relation("Kriteria1")
  perbandinganSebagaiKriteria2 PerbandinganKriteria[] @relation("Kriteria2")

  @@map("kriteria")
}

model SubKriteria {
  id         Int    @id @default(autoincrement()) @map("id_sub")
  kriteriaId Int    @map("kriteria_id")
  value      String
  skor       Float

  kriteria Kriteria @relation(fields: [kriteriaId], references: [id])

  @@map("sub_kriteria")
}

model RekomendasiRequest {
  id              Int      @id @default(autoincrement()) @map("id_rekomendasi")
  userId          Int      @map("user_id")
  kategoriHotelId Int      @map("kategori_hotel_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id])
  kategoriHotel KategoriHotel @relation(fields: [kategoriHotelId], references: [id])

  perbandingans    PerbandinganKriteria[]
  requestKriterias RekomendasiReqKriteria[]
  results          ResultRequest[]

  @@map("rekomendasi_request")
}

model RekomendasiReqKriteria {
  id            Int   @id @default(autoincrement()) @map("id_req")
  rekomendasiId Int   @map("id_rekomendasi")
  kriteriaId    Int   @map("kriteria_id")
  bobot         Float

  rekomendasi RekomendasiRequest @relation(fields: [rekomendasiId], references: [id])
  kriteria    Kriteria           @relation(fields: [kriteriaId], references: [id])

  @@map("rekomendasi_req_kriteria")
}

model ResultRequest {
  id            Int   @id @default(autoincrement()) @map("id_result")
  rekomendasiId Int   @map("id_rekomendasi")
  hotelId       Int   @map("id_hotel")
  score         Float
  ranking       Int   @map("rangking")

  rekomendasi RekomendasiRequest @relation(fields: [rekomendasiId], references: [id])
  hotel       Hotel              @relation(fields: [hotelId], references: [id])

  @@map("result_request")
}

model HotelKriteria {
  id Int @id @default(autoincrement())

  hotelId    Int @map("id_hotel")
  kriteriaId Int @map("id_kriteria")

  nilai Float

  hotel    Hotel    @relation(fields: [hotelId], references: [id])
  kriteria Kriteria @relation(fields: [kriteriaId], references: [id])

  @@unique([hotelId, kriteriaId])
  @@map("hotel_kriteria")
}

model PerbandinganKriteria {
  id Int @id @default(autoincrement())

  rekomendasiId Int @map("id_rekomendasi")

  kriteria1Id Int
  kriteria2Id Int

  nilai Float

  rekomendasi RekomendasiRequest @relation(fields: [rekomendasiId], references: [id])

  kriteria1 Kriteria @relation("Kriteria1", fields: [kriteria1Id], references: [id])

  kriteria2 Kriteria @relation("Kriteria2", fields: [kriteria2Id], references: [id])

  @@unique([rekomendasiId, kriteria1Id, kriteria2Id])
  @@map("perbandingan_kriteria")
}

model Booking {
  id Int @id @default(autoincrement())

  userId  Int @map("id_user")
  kamarId Int @map("id_kamar")

  checkIn  DateTime @map("check_in")
  checkOut DateTime @map("check_out")

  totalHarga Int @map("total_harga")

  status BookingStatus

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  kamar Kamar @relation(fields: [kamarId], references: [id])

  @@map("booking")
}

enum JenisKriteria {
  BENEFIT
  COST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECK_IN
  CHECK_OUT
  CANCELLED
}
